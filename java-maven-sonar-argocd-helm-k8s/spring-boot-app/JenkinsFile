pipeline {
  agent {
    docker {
      image 'abhishekf5/maven-abhishek-docker-agent:v1'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
    }
  }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/sathwikreddy12/Jenkins-Zero-To-Hero.git'
      }
    }
    stage('Build and Test') {
      steps {
        sh 'ls -ltr'
        // build the project and create a JAR file
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
      }
    }
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://18.119.229.59:9000"
        JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"
      }
      steps {
        sh 'apt-get update && apt-get install -y openjdk-17-jdk'
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
   stage('Build and Push Docker Image') {
    environment {
        DOCKER_IMAGE = "sathwik1reddy/ultimate-cicd:${BUILD_NUMBER}"
        REGISTRY_CREDENTIALS = credentials('docker-cred')
    }
    steps {
        script {
            // Login to DockerHub
            sh 'echo $REGISTRY_CREDENTIALS_PSW | docker login -u $REGISTRY_CREDENTIALS_USR --password-stdin'

            // Setup QEMU
            sh 'docker run --rm --privileged multiarch/qemu-user-static --reset -p yes'

            // Build AMD64 image
            sh "cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && docker build --platform linux/amd64 -t ${DOCKER_IMAGE}-amd64 ."

            // Build ARM64 image
            sh "cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && docker build --platform linux/arm64 -t ${DOCKER_IMAGE}-arm64 ."

            // Verify architectures
            sh "docker inspect ${DOCKER_IMAGE}-amd64 | grep -i arch"
            sh "docker inspect ${DOCKER_IMAGE}-arm64 | grep -i arch"

            // Push both images
            sh "docker push ${DOCKER_IMAGE}-amd64"
            sh "docker push ${DOCKER_IMAGE}-arm64"

            // Delete old manifest if exists
            sh "docker manifest rm ${DOCKER_IMAGE} || true"

            // Create and push manifest
            sh "docker manifest create ${DOCKER_IMAGE} ${DOCKER_IMAGE}-amd64 ${DOCKER_IMAGE}-arm64"
            sh "docker manifest annotate ${DOCKER_IMAGE} ${DOCKER_IMAGE}-amd64 --os linux --arch amd64"
            sh "docker manifest annotate ${DOCKER_IMAGE} ${DOCKER_IMAGE}-arm64 --os linux --arch arm64"
            sh "docker manifest push ${DOCKER_IMAGE}"
        }
    }
}
    stage('Update Deployment File') {
        environment {
            GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
            GIT_USER_NAME = "sathwikreddy12"
        }
        steps {
            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                sh '''
                    git config user.email "sathwikreddy1120@gmail.com"
                    git config user.name "sathwikreddy12"
                    git checkout main
                    git pull origin main
                    BUILD_NUMBER=${BUILD_NUMBER}
                    sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                    git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                '''
            }
        }
    }
  }
}
